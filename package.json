{
  "name": "terraform-preflight",
  "version": "0.2.0",
  "description": "Spin up a local AWS emulator (Floci), run a real terraform plan against it, and see the diff as an interactive graph before touching real infrastructure.",
  "keywords": [
    "terraform",
    "plan",
    "aws",
    "emulator",
    "visualization",
    "infrastructure",
    "ci"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Marcus4420/preflight.git"
  },
  "homepage": "https://github.com/Marcus4420/preflight#readme",
  "bugs": "https://github.com/Marcus4420/preflight/issues",
  "type": "module",
  "bin": {
    "terraform-preflight": "dist/cli.js"
  },
  "files": [
    "dist",
    "web/dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build --workspace=web",
    "prepublishOnly": "npm run build",
    "dev:web": "npm run dev --workspace=web",
    "start": "node dist/cli.js"
  },
  "workspaces": [
    "web"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "express": "^5.2.1",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
}
